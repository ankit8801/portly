rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isValidString(str, min, max) {
      return str is string && str.size() >= min && str.size() <= max;
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) 
                    && request.resource.data.uid == uid
                    && isValidString(request.resource.data.username, 3, 30);
      allow update: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.username == resource.data.username;
      allow delete: if false; 
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() 
                    && request.resource.data.uid == request.auth.uid
                    && !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow update: if false; 
    }

    match /portfolioSettings/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow read: if resource.data.status == "published" || isOwner(resource.data.ownerId);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data.ownerId) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner(resource.data.ownerId);
      
      match /blocks/{blockId} {
        allow read: if resource.data.status == "published" || isOwner(resource.data.ownerId);
        // Only allow creating if the new block data has the user's uid as ownerId
        allow create: if isOwner(request.resource.data.ownerId);
        allow update: if isOwner(resource.data.ownerId) && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isOwner(resource.data.ownerId);
      }
    }

    // Contact forms (legacy from previous CMS, optional but keep it secure if needed)
    match /contacts/{contactId} {
      allow create: if true; // public can submit
      allow read, update, delete: if false; // no longer admin-read here, maybe future dashboard
    }
  }
}
